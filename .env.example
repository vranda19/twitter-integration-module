# ============================================================================
# X (Twitter) OAuth 2.0 Credentials
# Obtained from: console.x.com -> Project -> App -> User authentication settings
# ============================================================================
TWITTER_CLIENT_ID=your_client_id_here
TWITTER_CLIENT_SECRET=your_client_secret_here
TWITTER_REDIRECT_URI=http://localhost:8000/twitter/callback
TWITTER_OAUTH_SCOPES=tweet.read tweet.write users.read offline.access

# ============================================================================
# X (Twitter) OAuth 1.0a (legacy — used by media upload paths)
# ============================================================================
TWITTER_API_KEY=your_api_key_here
TWITTER_API_KEY_SECRET=your_api_key_secret_here

# ============================================================================
# X (Twitter) App-only auth
# ============================================================================
TWITTER_BEARER_TOKEN=your_bearer_token_here

# ============================================================================
# Token encryption
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# ============================================================================
TOKEN_ENCRYPTION_KEY=your_generated_fernet_key_here

# ============================================================================
# Supabase (owned by platform team — this module only needs these three)
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# ============================================================================
# Upstash Redis (used for short-lived OAuth state/PKCE storage)
# ============================================================================
UPSTASH_REDIS_REST_URL=https://your-redis-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token_here

# ============================================================================
# Module behavior
# ============================================================================
FRONTEND_SUCCESS_REDIRECT_URL=http://localhost:3000/settings/integrations?status=success
FRONTEND_ERROR_REDIRECT_URL=http://localhost:3000/settings/integrations?status=error
LOG_LEVEL=INFO
ENVIRONMENT=development
